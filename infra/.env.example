# URSA-OSCAR environment variables.
# Copy to .env at the repo root; .env is gitignored. In production these are
# set in Dockge's per-stack environment editor, not in this file.

# --- MCP authentication (required — APEX template / ADR-002 pattern) -----
# Bearer token for SSE / static-auth fallback. Required at container start;
# missing -> ERROR exit. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
URSA_OSCAR_MCP_BEARER_TOKEN=replace-me

# Public URL the MCP server is reached at. Used to build OAuth metadata URLs.
# Local dev:    http://localhost:8085
# LAN:          http://<your-lan-ip>:8085
# Public:       https://your-public-host.example.com
URSA_OSCAR_MCP_BASE_URL=http://localhost:8085

# Pre-registered OAuth client. DCR is disabled. Required at container start.
#   python -c "import secrets; print(secrets.token_urlsafe(16))"
URSA_OSCAR_MCP_OAUTH_CLIENT_ID=replace-me
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
URSA_OSCAR_MCP_OAUTH_CLIENT_SECRET=replace-me

# --- Docker Hub ----------------------------------------------------------
DOCKERHUB_USER=brain40

# --- Host port overrides (defaults shown) --------------------------------
URSA_OSCAR_WEB_HOST_PORT=5063
URSA_OSCAR_MCP_HOST_PORT=8085
URSA_OSCAR_DEV_BYPASS_HOST_PORT=5065

# --- Volume host paths ---------------------------------------------------
# Production points these at the TrueNAS docker storage. Dev defaults to the
# repo's ./data and ./backend/tests/regression/fixtures via docker-compose.dev.yml.
URSA_OSCAR_DATA_PATH=./data
URSA_OSCAR_CPAP_IMPORT_PATH=./cpap-import
