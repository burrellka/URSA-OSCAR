# is intentionally tracked (it ships community defaults inside the wheel).
/data/
*.duckdb
*.duckdb.wal
*.duckdb-wal

# Secrets / env
.env
.env.local
*.env

# Phase 3 — work-in-progress docs that haven't been polished for the
# public Docs/ index. Kept locally for reference. Only finished,
# audited documentation lands in `Docs/` proper.
Docs/WIP/

# Phase 3 — personal CPAP regression fixtures (Kevin's own SD-card EDF
# data). Excluded from the public repo per the pre-publication scrub.
# Re-establish anonymized fixtures in Phase 4+ if community contributors
# need a deterministic regression target.
backend/tests/regression/fixtures/nights/oscar-reference/

# Same rationale — the parity test + canonical targets reference the
# private fixtures above. Kept locally for the operator's regression
# runs; excluded from the public repo until synthetic fixtures land.
backend/tests/regression/canonical_targets.py
backend/tests/regression/test_oscar_parity.py

# Local-only SD-card snapshots dropped at the repo root by the operator
# for ad-hoc importer / upload-endpoint debugging. Never published —
# this is real CPAP data, plus per-device serial numbers in
# IDENTIFICATION.* files.
/curr sd card/
/sd card/
/sd-card/

# Per-instance config (Phase 3) — vocabularies and user profile live
# on the mounted volume, never in git. Repo ships *.community-default
# stubs only (packaged inside backend/src/ursa_oscar/data/).
/data/vocab.json
/data/profile.json

